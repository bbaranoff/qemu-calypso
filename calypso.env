# calypso.env -- pipeline Calypso : s'enregistre (LU Accept) + MT-SMS + chiffrement A5/1.
# Sourcé par start-clean.sh avec `set -a` -> TOUT est exporté vers run.sh/qemu.
# [REQUIS] = couplé au code/fix, NE PAS retirer ni changer.  [tune] = ajustable.

# ============================================================================
# CAPTURE / ENREGISTREMENT
# ============================================================================
CALYPSO_CANNED=                 # vide = vrais SI décodés par grgsm (pas de SI bakés)
CALYPSO_IRDA_CAPTURE=0          # canal debug IrDA (off ; firmware IrDA perdu au reclone)
CALYPSO_TDMA_REALTIME=0
CALYPSO_ICOUNT=auto
# --- IQ côté DSP (BSP RX, post-AFC, bursts livrés au corrélateur) ---
# Format par burst : header 12o [magic 'IQ16' | fn LE 4o | tn 1o | n_int16 LE 2o | pad 1o]
#                    puis n × int16 LE (I/Q interleaved).
# Relecture : python3 fcch_ref.py /dev/shm/bursts.cfile --fmt int16 --burst N
# NB : ne s'écrit que si le chemin BSP RX/corrélateur est driver (limité en DSP_SHUNT=1).
BSP_DUMP_RX_FILE=/dev/shm/bursts.cfile
# CALYPSO_IQDUMP=1              # alt : 24 premiers bursts en fichiers séparés /tmp/iq_rx_NNN.bin + iq_dlv_NNN.bin

# --- IQ côté shunt (entrée DSP vue par le shunt, fc32) + record ring relai BTS ---
CALYPSO_SHUNT_IQ_CFILE=/dev/shm/dsp_iq.fifo   # fc32, FIFO live (FFT) — mkfifo avant QEMU (start-direct.sh)
CALYPSO_SHUNT_IQ_RECORD=/dev/shm/dsp_iq.cfile # fc32, record disque contigu (rejeu grgsm) EN PLUS de la FIFO ; vide=off
CALYPSO_UL_IQ_RECORD=/dev/shm/dsp_ul_iq.cfile # fc32, record I/Q UL synthetise (qemu_wrap, 4 SPS) ; vide=off
CALYPSO_RECORD_FILE=/dev/shm/record.cfile      # ring 128Mo (~15.5s) du relai DL osmo-trx

# --- 2 FIFOs grgsm : clair (jamais tué) + chiffré (spawné dans la fenêtre RAND) ---
# La 2e FIFO alimente en continu le 2e grgsm (-e -k) -> décode le DL chiffré SANS
# jamais retirer le lecteur de la FIFO clair (ce qui figeait l'ipc-device au cipher).
CALYPSO_RELAY_FIFOS=/tmp/iq_fft.fifo:/tmp/iq_grgsm.fifo:/tmp/iq_grgsm_ciph.fifo:/tmp/iq_record.fifo:/tmp/iq_asciifft.fifo

# ============================================================================
# CHIFFREMENT A5/1
# ============================================================================
# Kc capté par le filtre osmocon (L1CTL_CRYPTO_REQ) -> /dev/shm/calypso_kc :
#   [0..3]seq LE | [4]algo | [5]key_len=8 | [6..13]Kc | [14]CKSN. Clear sur DM_EST/DM_REL.
# UL  : qemu_wrap chiffre les bursts SDCCH montants (osmo_a5).
# DL  : si_bridge relance grgsm avec -e <algo> -k <Kc> dès qu'un Kc apparaît.
# BSC : osmo-bsc.cfg -> encryption a5 1.
CALYPSO_CIPH_A5=1                # vide = algo auto depuis /dev/shm/calypso_kc ; 1 = force A5/1
CALYPSO_CIPH_FN_ADJ=0          # [tune] ajustement FN du keystream UL (0 = aligné, vérifié au run)

# ============================================================================
# osmo-trx (Transceiver.cpp)
# ============================================================================
CALYPSO_START_FN=              # [REQUIS] horloge osmo-trx déterministe -> osmo_trx_fn == internal_fn
CALYPSO_NB_MAXDLY=40           # [REQUIS >0] fenêtre TOA burst normal (sinon SDCCH/SABM jamais détecté)

# ============================================================================
# UPLINK RACH / FN
# ============================================================================
CALYPSO_UL_DEBUG=
CALYPSO_UL_SLOT_OFFSET=        # [tune] TOA intra-slot du RACH (LU RACH-DET toa~4.6 = bon)
CALYPSO_UL_RA=                 # vide = RA auto
CALYPSO_UL_FN_GATE=            # [REQUIS] RACH injecté seulement sur slot éligible
CALYPSO_UL_FN_OFFSET=          # [REQUIS] bloc SDCCH (couplé à eff_ofs=15 : 36+15=51≡0 -> gate ~internal_fn).
                               #   NB : le gate RACH ignore désormais cet offset (corrigé : gate sur internal_fn).
CALYPSO_UL_RACH_STICKY=        # [tune MT-SMS] nb de slots RACH-éligibles où la paging-response (encodée 1×)
                               #   est ré-injectée depuis g_rach_iq. Monter (16) si la 2e RACH-DET manque.

# ============================================================================
# IMM ASSIGN req-ref (FN-fix)
# ============================================================================
CALYPSO_REQREF_ADJ=            # [REQUIS] req-ref = FN exact du RACH_CONF (ADJ!=0 -> mismatch). (rewrite à retirer via unif L1)

# ============================================================================
# SDCCH UL (SABM)
# ============================================================================
# CALYPSO_UL_SDCCH_OFS non défini -> eff_ofs=15 (offset déterministe ; Q pinné via ts_initial snap 102*5000).
CALYPSO_UL_SABM_HOLD_TTL=2     # [REQUIS] hold court : SABM décodée puis IDLE -> laisse passer le L3 (30 = flood)

# ============================================================================
# NOTES
# ============================================================================
# Run-variance résiduel (MT-SMS "marche une fois") : le mobile doit être CAMPÉ quand le paging
# arrive. L'horloge L1 du mobile (seed SCH grgsm) est encore l'horloge NON unifiée -> camping pas
# 100% stable run-à-run. Le fix propre = unifier la L1 sur internal_fn (== osmo-trx) -> stabilise le
# camping ET retire le req-ref rewrite. C'est la prochaine étape.

# ============================================================================
# [DIAG c54x revive - 2026-07-20] Reveil du vrai c54x_run + catcher crash-PC.
#   `:=` -> ne remplit QUE si absente : une valeur passee en CLI/env gagne
#   TOUJOURS (jamais ecrasee par ce fichier). Pour desactiver : commenter
#   ce bloc, ou exporter la var =0 en CLI.
#   - CALYPSO_DSP=c54x        : active shunt_route_c54x (assist NDB overlay)
#   - CALYPSO_DSP_RUN_C54X=1  : REVEILLE le vrai c54x_run (le chemin qui crashe)
#   - CALYPSO_C54X_CRASHPC=1  : arme le catcher SIGSEGV/ABRT/FPE/BUS
#                               -> imprime '[c54x] *** CRASH ... last_pc=0x.... ***'
# ============================================================================
: "${CALYPSO_DSP:=c54x}"
: "${CALYPSO_DSP_RUN_C54X:=1}"
: "${CALYPSO_C54X_CRASHPC:=1}"

# ############################################################################
# #  DISPONIBLES (diag) — fusion de l ancien calypso_diag.env, TOUT commente. #
# ############################################################################
# ============================================================================
# 1. CALYPSO_DEBUG — liste maitresse des sondes (comma-separated, un seul var)
# ============================================================================
# Decommente et compose la liste selon le besoin, ex:
#   CALYPSO_DEBUG=RSBX-INTM,POPM-ST1,IMR-W,BSP
# 82 tags trouves dans le code (calypso_debug_enabled("TAG")) :
#
# A-TRACE AFC-APPLY AR-TRACE AR2-FLOOR AR2-WR AR6-AT AR7-HIST AR_CLOBBER
# A_CD-BY-BURST A_SCH-WR BITF-PROBE BOOT-BRANCH BOOTSTUB-ENTRY BOOTSTUB_TRAIL
# BSP BSP-DELIVER BSP-RXBURST C54X CALAD-ZONE-W CALLSITE CORR-TRACE DARAM
# DATA-W-MMR DECODE-AUDIT DISP-ENTRY DISP-FLAG-W DISP-POLL DISP-PTR DISP-TRACE
# DISP-WRITE DISPATCH-ENTRY DROM-W-DROP DSP_WRITE_COUNT D_BURST_D-SUMMARY
# D_BURST_D-WR D_BURST_D_W-SUMMARY D_DSP_PAGE D_TASK_D-WR D_TASK_MD-RD
# D_TASK_MD_ALL HIT-76 IMR-W INSN-COUNT-STATS INT3-BLOCKED INT3-BLOCKED-SAMPLE
# INT3-CYCLE INT3_VEC INTM-TRANS IOTA IRQ-FRAME-HEALTH MVMD-AR7-BRC NDB-CTL-WR
# PAGE_SPLIT PC-HIST-3DD PC-HIST-3FB PCB PORTR-DEST-HIST PUMP READ-AMONT
# ROMMAP RPTB-ARMED R_PAGE_SPLIT SOFT_RESET_TRAIL SP-CATASTROPHE SP-DRAIN
# SP-GUARD SP-HIST SP-LOW SP-WATCH ST1-WR STACK-IN-NDB STUCK-HIST TPU_RAM TRAP
# TRX UPPER-DARAM WATCH-WRITE XC-COND XPC-STATS XPC-WR XPC1-PC-RING YIELD-BREAK
#
# Sous-ensemble documente/utilise cette session [SESSION] :
#   RSBX-INTM      : firing du fix SFTL/RSBX (bit ST0/ST1), confirme sain
#   POPM-ST1       : chaque POPM ST1 (PC=0x71e0, val=0x2900), cadence ~130 insn
#   IMR-W          : chaque write MMR IMR (inconditionnel dans la sonde IMR-ARM,
#                    voir plus bas — different de la sonde brute fprintf)
#   BSP            : trace generique BSP (DMA, delivery)
#
#CALYPSO_DEBUG=RSBX-INTM,POPM-ST1

# ============================================================================
# 2. Go-live / interruption / pile — coeur de l'investigation cette session
# ============================================================================

# [FIX, garder actif] Corrige la collision de masque RSBX/SSBX vs SFTL
# (0xF4Bx-0xF7Bx) qui faisait mal decoder RSBX INTM. Confirme sain, 0
# regression. C'est un vrai fix de decodeur, pas un diagnostic a desactiver.
#CALYPSO_FIX_SFTL_RSBX=1

# [SESSION, sonde RO] Log l'accumulateur A juste avant le CALA du wrapper
# generique 0x71c0-0x71f2 (dispatcher idle). Revele target=0xddd7 constant —
# le SM 5-cellules sain (0xdde0-0xde9f), pas la piste go-live.
#CALYPSO_CALA_71DA=1

# [FALSIFICATION, one-shot, deja utilise+reverte] Redirige la PREMIERE
# arrivee a PC=0xa4ca vers 0xa4c7, pour laisser le ROM executer sa vraie
# instruction ORM #0x3000,IMR. Confirme : IMR s'arme reellement (bit12/vec28).
# Addenda 20/22. NE PAS laisser actif en usage normal.
#CALYPSO_POKE_A4C7_ONCE=1

# [pre-existant, remap] Remappe la frame IT de vec19/bit3 vers le vrai
# scheduler vec28/bit12 (0x7234). Necessaire pour que l'armement IMR bit12
# (ci-dessus) ait un effet observable. Sans lui, IMR=0x3000 n'arme rien
# (bit3/vec19 reste a 0). Addendum 22.
#CALYPSO_DSP_FRAME_VEC28=1

# [SESSION, sonde RO, addendum 23/24] Trace la pile depuis l'entree vec28
# (push 2 mots PC+XPC) jusqu'a chaque RET/RETE/RCD/FRET, pour confirmer si un
# RET 1-mot depile le mot XPC orphelin. A utiliser AVEC les deux flags
# ci-dessus (sinon vec28 n'est jamais atteint pour armer la trace).
# Resultat confirme : storm PC=0x0000 via un RET pres de DARAM 0x0155,
# cascade "task=0x00b8" deja documentee (addenda 7-8, 22).
#CALYPSO_TRACE_VEC28_STACK=1

# [CODE, audit 2026-07-04] OR persistant sur IMR a CHAQUE step d'execution +
# clear conditionnel de INTM (calypso_c54x.c:12250-12273). Plus intrusif que
# POKE_A4C7_ONCE (celui-ci laisse le ROM executer sa propre instruction une
# fois ; celui-la force IMR en continu, tous les insn) — prefere toujours
# POKE_A4C7_ONCE pour une nouvelle experience.
#CALYPSO_C54X_FORCE_IMR=1

# [CODE, audit 2026-07-04] Restreint le clear one-shot de
# CALYPSO_FORCE_INTM_ONESHOT a un PC precis (calypso_c54x.c:998-1015).
# Sans effet seul -- doit accompagner FORCE_INTM_ONESHOT ci-dessous.
#CALYPSO_FORCE_INTM_AT_PC=0x0000

# [CODE, audit 2026-07-04] Clear ST1_INTM one-shot sur condition
# IFR/insn_count (calypso_c54x.c:994-1049,11933).
#CALYPSO_FORCE_INTM_ONESHOT=1

# [CODE, audit 2026-07-04] Semantique stricte BC TC/NTC restreinte a la
# fenetre PC [0xde0d,0xde26] (calypso_c54x.c:6403-6407) -- PAS un fix
# decodeur generique comme FIX_SFTL_RSBX, portee bien plus etroite.
#CALYPSO_C54X_BCTC_SM=1

# [CODE, audit 2026-07-04] Re-check l'IRQ pending a CHAQUE instruction au
# lieu du seul call-edge (calypso_c54x.c:4098-4133). Depend croisee avec
# CALYPSO_DSP_FRAME_VEC28.
#CALYPSO_C54X_IRQ_LEVEL=1

# ============================================================================
# 3. FBSB / DSP-shunt / orchestration hote — voir doc/calypso_fbsb_mecanisme.md
# ============================================================================

# [SESSION] Bascule vers le chemin MOCK (dsp_shunt.c) au lieu du vrai ROM
# c54x. Verifie INACTIF (=0) dans toutes les sessions live testees.
#CALYPSO_DSP_SHUNT=1

# [CODE, audit 2026-07-04, DOWNGRADE depuis SESSION] Lu UNIQUEMENT si
# CALYPSO_DSP_SHUNT=1 (calypso_dsp_shunt.c:223, shunt_route_c54x) -- INERTE
# en mode normal (DSP_SHUNT=0). "c54x" = pilote le vrai coeur via le shunt
# (DMA+IRQ+c54x_run reel) ; autre valeur = chemin mock synthetique pur.
#CALYPSO_DSP=c54x

# [SESSION] Gate maitre de calypso_orch() (calypso_orch.h) — active 3 sites
# d'ecriture directe dans data[] gardes par ce gate, dont le classifieur
# TONAL_FB de calypso_bsp.c:1222 qui ecrit directement data[0x08F8] (d_fb_det)
# selon une heuristique de forme de burst cote hote. ATTENTION : bug latent
# trouve cette session — bsp.fb_valid n'est jamais mis a 1 ailleurs dans le
# fichier, donc calypso_bsp_get_fb_detection() ne peut jamais retourner vrai
# meme avec ce gate actif (voir doc/calypso_fbsb_mecanisme.md §2c/§5).
#CALYPSO_ORCH=1

# [SESSION] Gate secondaire (avec CALYPSO_ORCH) pour la synthese FB dans
# calypso_fbsb.c::on_dsp_task_change(). Sans effet si CALYPSO_ORCH est absent
# (court-circuite par &&).
#CALYPSO_SYNTH_FBSB=1
#CALYPSO_DSP_L1_STUB=1

# [SESSION] Sonde en LECTURE (pas un forcage) : logge tout changement
# d'etat calypso-fbsb (task change), toujours actif par defaut dans les runs
# testes.
#CALYPSO_FBWATCH=1

# [SESSION] Sonde en LECTURE de toute ecriture STORE sur data[0x08f8]
# (d_fb_det), quelle que soit la valeur. Mode "=2" observe sans forcer.
# 0 hit sur toute la session = confirme que le vrai ROM DSP n'ecrit jamais
# ce mot (pas juste qu'il vaut 0 par coincidence).
#CALYPSO_FBDET_SENTINEL=2

# [DANGER confirme, audit 2026-07-04] Fait partie du combo qui, avec
# CALYPSO_ORCH=1 + CALYPSO_SYNTH_FBSB=1/CALYPSO_DSP_L1_STUB=1, active le
# chemin de SYNTHESE dans calypso_fbsb.c -- ecrit d_fb_det directement,
# PAS le vrai corrélateur DSP. Observe en session (2026-07-04) : provoque
# task=24 + d_fb_det non-zero de facon synthetique, faussement pris pour un
# "deblocage" du DSP reel. NE JAMAIS activer en config normale.
#CALYPSO_FORCE_FBSB=1
#CALYPSO_FORCE_GOLIVE=1

# [NOM, non verifie] Autres forcages similaires trouves par grep — meme
# reserve que ci-dessus, auditer le site d'appel avant toute activation.
#CALYPSO_FORCE_HS=1
#CALYPSO_FORCE_AGCH=1
#CALYPSO_FORCE_NB=1
#CALYPSO_FORCE_TOA=1
#CALYPSO_FORCE_098=1
#CALYPSO_FORCE_DP=1
#CALYPSO_FORCE_DP_FROM=0x0000

# [NOM, non verifie] Boot du go-live DSP — lie a VEC28-EXP (calypso_c54x.c,
# garde le frame_force pour ne pas derailler au boot). Voir commentaire
# c54x_interrupt_ex.
#CALYPSO_DSP_GOLIVE_BOOT=1

# [CODE, audit 2026-07-04] 2 gates fonctionnels reels dans
# shunt_dispatch_sb/allc (calypso_dsp_shunt.c:582,669) + diag (:1711) --
# c'est un verrou ANTI-triche (empeche le fallback canned), pas juste des
# "valeurs en boite" comme le nom le suggere. Vide/absent = vrais SI
# decodes par grgsm (comportement normal).
#CALYPSO_CANNED=1
#CALYPSO_SHUNT_NO_CANNED=1

# [NOM, non verifie] Familles d'injection shunt par canal logique (BCCH,
# AGCH, SDCCH, SACCH) — offsets/TTL/scheduling synthetiques.
#CALYPSO_SHUNT_AGCH=1
#CALYPSO_SHUNT_AGCH_OFS=0
#CALYPSO_SHUNT_AGCH_TTL=0
#CALYPSO_SHUNT_BCCH_OFS=0
#CALYPSO_SHUNT_BCCH_SCHED=1
#CALYPSO_SHUNT_SACCH=1
#CALYPSO_SHUNT_SDCCH=1
#CALYPSO_SHUNT_SDCCH_OFS=0
#CALYPSO_SHUNT_SDCCH_TTL=0
#CALYPSO_SHUNT_DL_INJECT=1
#CALYPSO_SHUNT_PM=1
#CALYPSO_SHUNT_GSMTAP_PORT=4729
#CALYPSO_SHUNT_SCH_PORT=0
#CALYPSO_SHUNT_IQ_CFILE=/path/to/file.cfile
#CALYPSO_SHUNT_IQ_CFILE2=/path/to/file2.cfile
#CALYPSO_SHUNT_IQ_RECORD=1

# ============================================================================
# 4. Memoire / pile / registres — watches generiques
# ============================================================================

# [SESSION, sonde RO] Surveille la zone DARAM 0x2b80 (watch-write generique
# utilise en tout debut de session pour la piste go-live, avant l'isolation
# des racines A/B precises).
#CALYPSO_MEM_WATCH_2B80=1

# [NOM, non verifie] Watch generique lecture/ecriture a une adresse donnee —
# probablement plus flexible que MEM_WATCH_2B80 (adresse parametrable).
#CALYPSO_WATCH_RD_ADDR=0x0000
#CALYPSO_WATCH_WR_ADDR=0x0000

# [CODE, audit 2026-07-04] Seuil SP armant l'histogramme, gate CALYPSO_DEBUG=
# SP-HIST (calypso_c54x.c:9896,10153-10162).
#CALYPSO_SP_HIST_ARM=0x2000
# [CODE] Mode trigger ring SP (floor/bootstub/both) -- ATTENTION, le
# commentaire source lui-meme est errone (annonce CALYPSO_SP_RING=1 comme
# gate, le vrai gate est CALYPSO_DEBUG=SP-RING, calypso_c54x.c:9942,10009-11).
#CALYPSO_SP_RING_TRIG=bootstub
# [CODE] Cap du nombre de dumps ring buffer (calypso_c54x.c:9941,10004-05).
#CALYPSO_SP_RING_MAX=4
# [CODE] Skip N insn avant armement du trigger bootstub (:9943-47,10013-14).
#CALYPSO_SP_RING_INSN_MIN=1000000
# [CODE] Seuil dump histogramme, distinct du ring buffer, meme dependance
# SP-HIST (calypso_c54x.c:9897,10154-10161).
#CALYPSO_SP_HIST_DUMP=0x0100

# [CODE, audit 2026-07-04] Log un STK-PUSH si la valeur ecrite matche.
# INERTE sans CALYPSO_ORPHAN=1 actif aussi (calypso_c54x.c:2296-2312).
#CALYPSO_TRACK_STKVAL=0x3125

# [NOM, non verifie] Trace generique des registres AR (auxiliary registers).
#CALYPSO_AR_TRACE=1
#CALYPSO_AR2_FLOOR_DROP=1
#CALYPSO_AR6_AT_PC=0x0000
#CALYPSO_AR6_AT_LOG_CAP=50
#CALYPSO_AR6_WIN_LO=0x0000
#CALYPSO_AR6_WIN_HI=0xffff

# [NOM, non verifie] Trace de l'accumulateur A a une PC donnee.
#CALYPSO_A_TRACE_PC=0x0000
#CALYPSO_B3_TRACE=1

# [MORT, confirme audit 2026-07-04] Mecanisme RETIRE le 2026-05-29 :
# trap_armed est force a 0 en dur juste avant la lecture de cette variable
# (calypso_c54x.c:13251-13252, commentaire "TRAP-OOR RETIRED"). Aucune
# valeur ne peut la reactiver sans modifier le code. NE PAS activer.
#CALYPSO_TRAP_CHECKPOINT=1

# [NOM, non verifie] Detection generique (nom trop court pour deviner le
# perimetre exact) — grep calypso_c54x.c avant usage.
#CALYPSO_DETTRACE=1
#CALYPSO_SM_TRACE=1

# [CODE, audit 2026-07-04, CORRIGE] Gate DIRECT getenv("CALYPSO_ORPHAN")
# (calypso_c54x.c:2297,12825) -- PAS via CALYPSO_DEBUG=ORPHAN comme un
# commentaire precedent le laissait entendre a tort. Necessaire pour que
# CALYPSO_TRACK_STKVAL (ci-dessus) ait un effet.
#CALYPSO_ORPHAN=1

# [CODE, confirme via commentaire] Mode chargement registres DSP au reset :
# 0=c54x natif, 1=bin brut, 2=hybride.
#CALYPSO_DSP_REG_MODE=0

# ============================================================================
# 5. Decodeur / audit opcode
# ============================================================================

# [FIX, garder actif] Fix MVDM (mouvement de donnees) deja valide, cf
# REVERT_MVMD_KNOWLEDGE.md pour l'historique du saga associe.
#CALYPSO_FIX_MVDM=1

# [FIX, garder actif] Fix decodage PORTR (port radio, PA=0xF430 vs alias
# legacy 0x0034).
#CALYPSO_FIX_PORTR=1

# [SESSION, outil d'audit] Fenetre d'audit decodeur (Decode-Audit) —
# CALYPSO_DA_LO/HI bornent la plage PC, CALYPSO_DA_INSN le nombre
# d'instructions a logger. Utilise pour chasser les bugs MVDM/STH/CMPS
# historiques (addenda anciens).
#CALYPSO_DA_LO=0x0000
#CALYPSO_DA_HI=0xffff
#CALYPSO_DA_INSN=250000000

# [NOM, non verifie] Trace de LD/STL a une PC donnee.
#CALYPSO_TRACE_LDU_PC=0x0000
#CALYPSO_TRACE_STLD_PC=0x0000

# ============================================================================
# 6. Timing / TDMA / cadence
# ============================================================================

# [CODE] Periode TDMA en nanosecondes (defaut normalement geré par
# calypso.env, pas ce fichier diag — a ne toucher qu'en experimentation).
#CALYPSO_TDMA_NS=4615000

# [CODE] Bascule horloge TDMA reelle (wall-clock) vs virtuelle QEMU —
# tradeoff jitter documente dans calypso.env.
#CALYPSO_TDMA_REALTIME=1

# [CODE] Budget d'instructions DSP par frame TDMA (defaut 256000, voir
# CALA/VEC28-STACK-TRACE logs qui le citent).
#CALYPSO_DSP_BUDGET=256000

# [CODE, audit 2026-07-04] Fast-forward la boucle de polling DSP connue
# (calypso_c54x.c:9750-9848, appel :11056-11065) -- INERTE si
# CALYPSO_DSP_SHUNT=1 actif (c54x_run jamais appele) ou si CALYPSO_DEBUG
# ne contient pas C54X (log gated, meme mecanisme actif = pas de preuve).
#CALYPSO_DSP_IDLE_FF=1
#CALYPSO_DSP_YIELD=1
# [CODE] Gouverneur de park du vCPU ARM946 (calypso_trx.c:1290-1338,
# gate 1315-1323) -- MECANISME DIFFERENT de DSP_IDLE_FF ci-dessus malgre
# le nom similaire (celui-ci est cote ARM, DSP_IDLE_FF est cote DSP c54x).
# Opt-out (actif par defaut) ; window derivee par nm() sur le firmware ELF
# (run.sh:1826-1835). Confirme en live : log "[cpu-idle] governor ON
# window=[lo,hi]" matche exactement les valeurs CALYPSO_IDLE_PC_LO/HI.
#CALYPSO_CPU_IDLE=1

# [CODE, confirme] Choix de conception (pas un bug) : le tick INT3 periodique
# reste arme meme si IMR ne l'est pas, pour casser un verrou circulaire.
# Documente calypso_trx.c:1766-1798. Ne pas confondre avec le blocage
# IMR/vec28 lui-meme (racine A).
#CALYPSO_FRAME_FAITHFUL=1

# [NOM, non verifie] Nombre max d'iterations de la boucle de boot MVPD
# (copie PROM0->DARAM).
#CALYPSO_MVPD_BOOT_LIMIT=0

# [DANGER confirme, audit 2026-07-04] NE JAMAIS ACTIVER. Le sous-systeme
# producteur (spawn de QemuThread par composant PCB) a ete SUPPRIME au
# commit 4b93329 (calypso_full_pcb.c, header dit desormais "Does NOT own
# any timer or clock"), mais 2 lecteurs getenv() existent TOUJOURS
# (calypso_tint0.c:60, calypso_trx.c:2153). Activer cette variable
# aujourd'hui ne reactiverait rien MAIS GELERAIT LE TICK TDMA, car le
# timer ne serait plus jamais re-arme (calypso_tint0.c:60 : le re-arm est
# conditionne sur "!pcb_threaded"). Variable a supprimer purement et
# simplement, pas juste a laisser OFF.
#CALYPSO_PCB_TICK_THREADS=1

# ============================================================================
# 7. BSP / IQ / reseau
# ============================================================================

# [NOM, non verifie] Desactive le gate IFR.bit3 avant re-livraison INT3 (BSP),
# ou le rend inconditionnel — inverse logique probable entre les deux noms.
#CALYPSO_BSP_INT3_OFF=1
#CALYPSO_BSP_INT3_UNGATED=1

# [NOM, non verifie] Passthrough IQ direct (bypass DMA/traitement BSP ?).
#CALYPSO_BSP_IQ_PASSTHROUGH=1

# [NOM, non verifie] Rejoue un fichier de capture au lieu du flux UDP live.
#CALYPSO_BSP_REPLAY_FILE=/path/to/replay.cfile

# [NOM, non verifie] Bind reseau BSP (adresse/loopback/port).
#CALYPSO_BSP_BIND_ADDR=0.0.0.0
#CALYPSO_BSP_BIND_LOOPBACK=1
#CALYPSO_BSP_PORT=6702

# [NOM, non verifie] Dump IQ brut vers fichier, format cfile, taille
# d'echantillon par frame (spf).
#CALYPSO_IQDUMP=1
#CALYPSO_IQ_CFILE_SPF=148
#CALYPSO_IQ_TEE_HOST=127.0.0.1
#CALYPSO_IQ_TEE_PORT=0

# [CODE, audit 2026-07-04, CORRECTION] C'est un OPT-OUT (actif par defaut,
# PAS un forcage) qui active la vraie boucle AFC (calypso_twl3025.c:99-100).
# Un commentaire precedent disait a tort "force une valeur" -- c'est
# l'inverse : =0 desactiverait la boucle reelle.
#CALYPSO_TWL3025_AFC=1
# [CODE] Override Hz prioritaire sur le calcul reel SI non-nul
# (calypso_twl3025.c:94-95,155). Vide/0 = calcul reel utilise (normal).
#CALYPSO_TWL3025_AFC_HZ=0

# [NOM, non verifie] Offset RACH/frame-number pour le decodage UL.
#CALYPSO_NDB_D_RACH_OFFSET=0x023a
#CALYPSO_DL_FN_OFFSET=0
#CALYPSO_UL_ACU_OFS=0
#CALYPSO_UL_PUB_IDLE=1
#CALYPSO_L1S_FN_ADDR=0x00000000
#CALYPSO_LAST_RACH_FN_ADDR=0x00000000
#CALYPSO_NB_DATAIND=1

# [NOM, non verifie] Force le BSIC dans l'encodeur RACH (au lieu du byte
# d_rach reel) — utile pour matcher `base_station_id_code` d'osmo-bsc.cfg.
#CALYPSO_RACH_FORCE_BSIC=0

# [NOM, non verifie] Redirection d'ecriture PROM/legacy — perimetre exact non
# caracterise cette session.
#CALYPSO_REDIR7000=1
#CALYPSO_REDIR_LEGACY=1

# [CODE, confirme via commentaire] Reecriture du request-reference RACH :
# REWRITE=global (ancien, 50% multi-RACH, defaut OFF) vs PERRA=par-RA (FN
# exact du RACH_CONF keye par ra, defaut ON).
#CALYPSO_REQREF_REWRITE=1
#CALYPSO_REQREF_PERRA=0
#CALYPSO_REQREF_ADJ=0

# [NOM, non verifie] Table d'init generique (contenu/perimetre a verifier).
#CALYPSO_INITTAB=1

# [NOM, non verifie] Trace UART generique.
#CALYPSO_UART_TRACE=1

# [NOM, non verifie] Seed de la pile au boot (valeur 0x5AC8 deja vue dans les
# addenda comme adresse de reset SP typique — a confirmer).
#CALYPSO_SEED5AC8=1

# [CODE, confirme via commentaire] Fenetre d'adresses ou le dispatcher idle
# est considere "en zone connue" (utilise par CALYPSO_DSP_IDLE_FF pour savoir
# ou accelerer).
#CALYPSO_DSP_IDLE_RANGE=0xe9ac:0xe9b7,0xcc62:0xcc6f
#CALYPSO_IDLE_PC_LO=0x0000
#CALYPSO_IDLE_PC_HI=0xffff

# [NOM, non verifie] Fenetre de correlation (previously seen in correlateur
# FB context, non confirme quel exact usage).
#CALYPSO_CORR_LO=0x0000
#CALYPSO_CORR_HI=0xffff

# [CODE, audit 2026-07-04] Charge IMSI/Ki dans la SIM emulee QEMU
# (calypso_sim.c:720,787) -- confirme en live, log "[sim] EF_IMSI loaded
# from ...".
#CALYPSO_SIM_CFG=/root/.osmocom/bb/mobile_group1.cfg

# [NOM, non verifie] Passerelle ARM->DSP (bridge session), continuation.
#CALYPSO_ARM2DSP=1
#CALYPSO_ARM2DSP_CONT=1

# [NOM, non verifie] Blob DSP de test (charge un binaire arbitraire en DARAM
# au lieu du boot ROM normal — outil de test/fixture, pas pour usage normal).
#CALYPSO_DSP_BLOB=/path/to/blob.bin

# ============================================================================
# 8. Niveau shell (bash_scripts/run.sh) — PAS getenv() C, decouvert 2026-07-04
# ============================================================================
# Ces variables ne pilotent pas QEMU/c54x directement : elles controlent quels
# PROCESSUS EXTERNES run.sh lance (BTS, mobile, ipc-device...). Zero
# getenv("CALYPSO_SKIP_...") trouve dans tout le C -- confirme par grep
# exhaustif. Absentes du grep C qui a genere les sections 1-7 par construction.
# Preset CALYPSO_MODE=full (run.sh:1140-1148) :
#   CALYPSO_SKIP_IPC_DEVICE:=0   CALYPSO_SKIP_TRX_IPC:=0
#   CALYPSO_SKIP_BTS:=0          CALYPSO_SKIP_L2:=0
#   CALYPSO_SKIP_GSMTAP:=0       CALYPSO_SKIP_BRIDGE_PY:=1
# [CODE, SESSION] confirme comportementalement (bursts delivres, dialogue
# L1CTL mobile reel) sur un run CALYPSO_MODE=full equivalent.
#CALYPSO_SKIP_IPC_DEVICE=0   # run.sh:1967 -- coupe le pont IPC device<->QEMU BSP (UDP 6702)
#CALYPSO_SKIP_TRX_IPC=0      # run.sh:1995 -- coupe la couche TRX IPC entre BTS et device
#CALYPSO_SKIP_BTS=0          # run.sh:2024 -- coupe la BTS complete (osmo-bts-trx)
#CALYPSO_SKIP_L2=0           # run.sh:2139-2145 -- coupe le client layer23 `mobile` (SIM/RR/MM)
#CALYPSO_SKIP_GSMTAP=0       # run.sh:2176-2182 -- coupe la capture tcpdump port 4729
#CALYPSO_SKIP_BRIDGE_PY=1    # run.sh:2006 -- lance/coupe le pont Python legacy bridge.py (mutex avec ipc-device/trx-ipc, run.sh:1279)
#CALYPSO_SKIP_DEMOD_BRIDGE=1 # run.sh:2039-2040 -- lance/coupe qemu_bcch_grgsm.py ; pertinent SEULEMENT si CALYPSO_DSP_SHUNT=1, sans effet en mode full

# ============================================================================
# 9. Variables vestigiales / mortes — NE PAS COMPTER SUR ELLES
# ============================================================================
# [MORT, audit 2026-07-04] Declaree dans calypso_trx.h:126-129 ("Returns 1 if
# CALYPSO_W1C_LATCH=1") mais AUCUNE implementation/site d'appel dans tout
# qemu-src (grep exhaustif = 0). Mecanisme retire le 2026-05-28
# (calypso_c54x.c:3450-3453). run.sh continue de l'exporter et de la
# presenter comme critique (run.sh:1338,1354,2412) -- commentaire de
# launcher activement trompeur, a corriger un jour dans run.sh lui-meme.
#CALYPSO_W1C_LATCH=1

# [VESTIGIALE, audit 2026-07-04] Le vrai gate est le token CALYPSO_DEBUG=TIMER
# (calypso_trx.c:47-52, calypso_debug.h:79-83), PAS cette variable standalone
# documentee a tort par run.sh:1365-1368,2417. Sans effet seule.
#CALYPSO_TIMER=0

# [VESTIGIALE, audit 2026-07-04] Meme pattern que CALYPSO_TIMER : le vrai
# gate est CALYPSO_DEBUG=BOOTSTUB (calypso_c54x.c:4410,4447,4483,4526,4571),
# pas cette variable documentee a tort par run.sh:1346,2411.
#CALYPSO_PROBE_BOOTSTUB=0

# [NEUTRALISE par defaut, audit 2026-07-04] CALYPSO_REDIR7000/CALYPSO_INITTAB
# sont nested sous CALYPSO_REDIR_LEGACY (calypso_c54x.c:10818-10845), lui-meme
# neutralise par defaut depuis le 2026-05-31 ("REDIRECT NEUTRALISE PAR
# DEFAUT"). Si CALYPSO_REDIR_LEGACY est absente (cas nominal), ces variables
# ne sont meme pas lues.

# ============================================================================
# FIN — pour toute variable marquee [NOM], grep le fichier source avant
# activation :
#   grep -n "getenv(\"CALYPSO_XXX\")" hw/arm/calypso/*.c hw/*/calypso_*.c
# et lis 10-20 lignes de contexte pour confirmer effet exact et defaut.
# ============================================================================

# ############################################################################
# #  DISPONIBLES — AUTRES KNOBS (shell / orchestration / ROM / RF / UL-tune)  #
# #  Toutes COMMENTEES (OFF). Decommenter = activer. NB correctness : une var #
# #  laissee active mais VIDE est exportee "" (set -a) -> getenv() renvoie "" #
# #  non-NULL : pour les knobs testes par PRESENCE, laisser COMMENTE, ne pas  #
# #  faire "VAR=". (Section fusionnee depuis l'ancien calypso_diag.env.)      #
# ############################################################################

# ============================================================================
# ORCHESTRATION / MODE (lu par run.sh, pas par qemu)
# ============================================================================
# CALYPSO_MODE=full-grgsm        # mode pipeline : full-grgsm|full|shunt|shunt-ipc|bridge|bare|free
# CALYPSO_MODE_TAG=              # tag de mode affiche dans le menu/logs
# CALYPSO_L2_CLIENT=mobile       # client L2 : mobile | ccch_scan | cell_log
# CALYPSO_NO_ATTACH=1            # 1 = pipeline en background (pas d'attach tmux final)
# CALYPSO_MTTCG=0                # multi-thread TCG (mutuellement exclusif avec icount)
# CALYPSO_QEMU_HALT=0            # 1 = -S au launch (gdb attach avant boot)
# CALYPSO_AUTO_GEN_DOC=0         # 1 = genere doc/menu au boot (defaut run.sh = 1)
# CALYPSO_MENU_THEME=            # theme whiptail du menu run.sh
# CALYPSO_CONTAINER=             # nom du container docker
# CALYPSO_REPO=                  # racine du repo qemu-src
# CALYPSO_HOST_ROOT=/root        # racine cote hote
# CALYPSO_LOGDIR=                # repertoire des logs du run
# CALYPSO_LOG_TS=                # prefixe timestamp des logs
# CALYPSO_TEST_OUT=              # repertoire de sortie des tests
# CALYPSO_PYTEST=                # active la campagne pytest
# CALYPSO_PYTEST_SCOPE=          # scope pytest
# CALYPSO_PYTEST_VERBOSITY=      # verbosite pytest
# CALYPSO_SYNC_MOBILE_CFG=       # sync auto du mobile.cfg
# CALYPSO_STICK_ARFCN=           # pin ARFCN dans mobile.cfg (override)
# CALYPSO_MOBILE_DEBUG=          # debug du client mobile osmocom-bb
# CALYPSO_MOBILE_DELAY=          # delai de demarrage du mobile
# CALYPSO_SKIP_GDB_PANE=         # 1 = pas de pane gdb dans la fenetre 'all'
# CALYPSO_SKIP_DECODE_PANES=     # 1 = pas de panes de decode (grgsm/gsmtap)
# CALYPSO_TRAP_OOR=              # trap sur acces memoire out-of-range

# ============================================================================
# GDB (debug firmware ARM / DSP c54x)
# ============================================================================
# CALYPSO_GDB_ELF=               # ELF firmware pour gdb
# CALYPSO_GDB_PORT=              # port gdbserver de qemu
# CALYPSO_GDB_PANE=              # 1 = ouvre un pane gdb
# CALYPSO_GDB_PANE_SCRIPT=       # script gdb du pane
# CALYPSO_GDB_SCRIPT=            # script gdb applique au launch

# ============================================================================
# BRIDGES / DECODERS (chemins scripts, lu par run.sh)
# ============================================================================
# CALYPSO_BRIDGE_PYTHON=/root/.env/bin/python3   # interpreteur python des bridges
# CALYPSO_SI_BRIDGE=             # chemin si_bridge.py
# CALYPSO_DEMOD_BRIDGE=          # chemin du demod-bridge
# CALYPSO_GRGSM_DECODER=         # binaire/script grgsm decode
# CALYPSO_IPC_DEVICE=            # binaire calypso-ipc-device
# CALYPSO_IPC_DEVICE_DEFAULT=    # chemin par defaut de l'ipc-device
# CALYPSO_HLR_VTY_IP=            # IP VTY osmo-hlr (feed IMSI/Ki A5/1)

# ============================================================================
# DSP c54x — BLOBS ROM / DROM / REGISTRES (chemins, -> args qemu)
# ============================================================================
# CALYPSO_DSP_ROM=              # blob PROM DSP (code programme)
# CALYPSO_DSP_ROM_TXT=          # dump texte du ROM DSP
# CALYPSO_DSP_DROM=             # blob DROM DSP (donnees)
# CALYPSO_DSP_PDROM=            # blob P/DROM combine
# CALYPSO_DSP_PROM0=            # segment PROM0 DSP
# CALYPSO_DSP_PROM1=            # segment PROM1 DSP
# CALYPSO_DSP_PROM2=            # segment PROM2 DSP
# CALYPSO_DSP_PROM3=            # segment PROM3 DSP
# CALYPSO_DSP_REGISTERS=        # dump registres init DSP
# CALYPSO_DSP_L1STUB=           # 1 = patch PROM0@0x7120 = publisher stub

# ============================================================================
# RF / IQ / TRX / TIMING TDMA (functional knobs)
# ============================================================================
# CALYPSO_L1=                   # mode L1 : 'c' = layer1.c natif (FB/SB reels)
# CALYPSO_CCCH_ARFCN=514        # ARFCN du CCCH (decodeur grgsm/gsmtap)
# CALYPSO_BSP_DARAM_ADDR=0x2a00 # adresse DARAM BSP RX (canary-validated)
# CALYPSO_BSP_HOST=             # hote UDP source du flux IQ BSP RX
# CALYPSO_TRX_IQ_HOST=          # hote endpoint IQ osmo-trx
# CALYPSO_TRX_IQ_RX_PORT=       # port IQ RX osmo-trx
# CALYPSO_TRX_IQ_TX_PORT=       # port IQ TX osmo-trx
# CALYPSO_SAMPLE_RATE=          # taux d'echantillonnage radio
# CALYPSO_DOPPLER_HZ=           # decalage doppler simule (Hz)
# CALYPSO_DL_BURST_OFFSET=      # offset burst DL
# CALYPSO_DL_IQ_CONJ=           # conjugaison IQ DL (1 = inverse le sens spectral)
# CALYPSO_QFN_FLOOR_NS=         # plancher quantum FN (ns) — timing TDMA
# CALYPSO_QFN_FORCE=            # force le quantum FN
# CALYPSO_QFN_LEAD=             # avance quantum FN
# CALYPSO_RELAY_ALSO_BSP=       # relaie aussi le flux vers le BSP
# CALYPSO_IPC_RELAY=            # relais IPC
# CALYPSO_IPC_UL=               # relais IPC uplink
# CALYPSO_IRDA_PEER=0           # peer IrDA actif (OFF : vole le timing TDMA -> no cell info)
# CALYPSO_LOST_LATCH=           # latch anti-'LOST' cote osmocon (frame-locked)

# ============================================================================
# BURST / FCCH DEBUG
# ============================================================================
# CALYPSO_BURST_PRINT=0         # 1 = imprime les bursts I/Q
# CALYPSO_BURST_HEAD=           # nb de bursts d'entete a tracer
# CALYPSO_BURST_MAX=            # nb max de bursts traces
# CALYPSO_FCCH_DUMP=            # dump des bursts FCCH
# CALYPSO_FCCH_DUMP_N=          # nb de FCCH a dumper
# CALYPSO_FCCH_DUMP_SKIP=       # nb de FCCH a sauter avant dump

# ============================================================================
# UPLINK — TUNING FIN (value knobs ; [tune], laisser vide = defaut code)
# ============================================================================
# CALYPSO_UL_AMP=               # amplitude du burst UL synthetise
# CALYPSO_UL_GMSK=              # mode/parametre GMSK UL
# CALYPSO_UL_INVERT=            # inversion du signal UL
# CALYPSO_UL_ROT=               # rotation de phase UL
# CALYPSO_UL_ROT_SGN=           # signe de la rotation UL
# CALYPSO_UL_ACTIVE_SYMS=       # nb de symboles actifs dans le burst UL
# CALYPSO_UL_BSIC=              # BSIC force cote UL
# CALYPSO_UL_FN_ADJ=            # ajustement FN UL
# CALYPSO_UL_FN_LOCK=           # lock FN UL
# CALYPSO_UL_RACH_ENC=          # variante d'encodage RACH UL
# CALYPSO_UL_SDCCH=             # active/parametre SDCCH UL
# CALYPSO_UL_SDCCH_SMP_OFS=     # offset d'echantillonnage SDCCH UL
# CALYPSO_UL_SABM_HOLD=         # hold SABM (variante de UL_SABM_HOLD_TTL, cf necessaires)
# CALYPSO_UL_SABM_STICKY=       # re-injection sticky de la SABM
# CALYPSO_UL_SABM_TTL=          # TTL SABM
# CALYPSO_FORCE_INTM_CLEAR_AT=  # force clear INTM du DSP a une PC donnee
# CALYPSO_DBG=                  # flag debug generique
