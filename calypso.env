# calypso.env — pipeline Calypso : no_shunt (vrai DSP c54x) + LU/MT-4SMS + A5/1.
# Sourcé par start-clean.sh avec `set -a`. [REQUIS]=couplé au code. [tune]=ajustable.
#
# ÉTAT CHAÎNE no_shunt (2026-07-11) :
#   RSBX INTM ✅ (FIX_SFTL_RSBX) → IMR armable ✅ (FORCE_IMR/self) → frame→vec28 ✅ (FRAME_VEC28)
#   → FB0_SEARCH réel tourne ✅ … MAIS bloqué au handshake go-live (cellules 0x098a-0x098e,
#   multi-cellules avec reclears @0xdded/0xde88). Les forces one-shot (FORCE_098/FORCE_HS)
#   échouent (recleared). Fix faithful arm2dsp EN COURS (workflow map-golive-handshake).
  
# ============================================================================
# DSP — cœur no_shunt (vrai c54x TMS320C54x)
# ============================================================================
CALYPSO_DSP=c54x             # vrai DSP (pas le mock gr-gsm)
CALYPSO_DSP_SHUNT=0          # 0 = vrai c54x émulé (pas le shunt C)
CALYPSO_MODE=full            # pipeline complet (osmo-trx/BTS/IPC/L2)
CALYPSO_DSP_REG_MODE=bin     # registres du dump 3606 (IMR=0x3000 SP=0x1100) — c'est ce mode qui atteint FB0_SEARCH
CALYPSO_ICOUNT=off
CALYPSO_TDMA_REALTIME=1      # [REQUIS faketrx] tick TDMA sur wall-clock (sinon 87-99% drop bursts)
CALYPSO_BSP_IQ_PASSTHROUGH=1 # IQ réel osmo-trx → BSP → DARAM → corrélateur
CALYPSO_DSP_IDLE_FF=0        # [perf] 1=fast-forward les idle-poll loops (0xcc62/0xe9ac). Orthogonal au blocker.

# ============================================================================
# DSP — FIXES émulateur CONFIRMÉS (garder ON)
# ============================================================================
CALYPSO_FIX_SFTL_RSBX=1     # ✅ PROUVÉ : 0xF6BB(RSBX INTM) mal-décodé en SFTL (0xF6BB&0xFCE0=0xF4A0) → INTM clear @0xa6cf OK
CALYPSO_DSP_FRAME_VEC28=0   # ✅ PROUVÉ : frame IT → vec28/bit12 (VRAI scheduler 0x7234→corrélateur), au lieu du stub vec19. REQUIS pour un vrai FB.
CALYPSO_FIX_MVDM=1          # fix décode MVDM
CALYPSO_FIX_PORTR=1         # fix PORTR
CALYPSO_FRAME_FAITHFUL=1    # frame handling faithful
  
# ============================================================================
# DSP — BRIDGE ARM→DSP faithful (task-post data[0x0fff])
# ============================================================================
CALYPSO_ARM2DSP=0           # poste task-ready quand l'ARM écrit B_GSM_TASK (dispatcher ROM 0xb41c)
CALYPSO_ARM2DSP_CONT=1      # re-post continu (tient à travers le clear b419)
  
# ============================================================================
# DSP — GO-LIVE HANDSHAKE  ← LE BLOCKER ACTUEL (frontière no_shunt)
# ============================================================================
# La wait-loop 0xa4d4 (CMPM data[0x3f70],#2) ne sort que si un setter (0xde9c/0xa5bd/…)
# pose 0x3f70 bit1, GATÉ par un handshake multi-cellules 0x098a-0x098e AVEC RECLEARS :
#   098a≠0 → passe reclear#1 @0xdded | 098c≠0 → reclear#2 @0xde88 | 098d≠0 → anti-loop de82
#   098b/098e = compteurs ADD/BANZ (à bracketer)
# → un poke ONE-SHOT est recleared au tour suivant. Ces knobs ÉCHOUENT (laissés OFF) :
#CALYPSO_FORCE_HS=0x0001    # override valeur ARM sur 0x0314/0x0318 → recleared @0xdded. ÉCHEC.
#CALYPSO_FORCE_098=0x0001   # poke DSP data[098a/c] → recleared. ÉCHEC.
#CALYPSO_FORCE_GOLIVE=0     # set brut 0x3f70 bit1 (triche, bypasse le handshake). Éviter.
#CALYPSO_DSP_GOLIVE_BOOT=1  # EXPÉRIENCE (B) redirect go-live. Non retenu.
# FALLBACK si VEC28 n'auto-arme pas IMR (self-arm @0xa582 attendu après go-live) :
#CALYPSO_C54X_FORCE_IMR=0x52fd # arme IMR (bit3 INT3 + bit5 + bit12 vec28) + clear INTM dans l'idle-loop. PROUVÉ armer IMR.
# → LE VRAI FIX (faithful, côté ARM = pourquoi l'ARM laisse 0x098a=0) est en cours de design (workflow).

# ============================================================================
# DSP — ORACLE (temporaire) + diagnostics
# ============================================================================
CALYPSO_FORCE_FBSB=0        # ⚠️  ORACLE : force FBSB côté L1 pour garder l'ARM vivant (registration/SMS) TANT QUE le vrai DSP ne locke pas FB. À PASSER À 0 quand go-live+corrélateur marchent (critère de succès honnête).
CALYPSO_FBDET_SENTINEL=2    # sonde : compte les écritures d_fb_det (0 = DSP réel n'écrit jamais)
CALYPSO_DEBUG=RSBX-INTM,POPM-ST1
CALYPSO_ORPHAN=1           # [diag] trace RET/IT orphelins (env dédiée, anti-Heisenbug)
CALYPSO_FBWATCH=1          # [diag] watch FB
CALYPSO_SEED5AC8=0        # [diag] expérience chaînon go-live 5AC8
CALYPSO_MEM_WATCH_2B80=1  # [diag] watch corrélateur 0x2b80
CALYPSO_CALA_71DA=1      # [diag] cible CALA dispatcher générique 0x71c0
CALYPSO_L2_CLIENT=mobile
#CALYPSO_SM_TRACE=1       # [trace on-demand] state-machine go-live
#CALYPSO_B3_TRACE=1       # [trace on-demand]
CALYPSO_C54X_BCTC_SM=1   # [trace on-demand]
#CALYPSO_C54X_IRQ_LEVEL=1 # [trace on-demand]
# ============================================================================
# OBSOLÈTE — arm2dsp forceur retiré 2026-07-02 (self-loop PC=0x0000). NE PAS réactiver.
# ============================================================================
#CALYPSO_ARM2DSP_TGT=0x7234#CALYPSO_ARM2DSP_435B=0 #CALYPSO_ARM2DSP_SP=0x1100
#CALYPSO_ARM2DSP_N=1000    #CALYPSO_ARM2DSP_NOREDIR=1 #CALYPSO_ARM2DSP_IMR=0#CALYPSO_ARM2DSP_ENAI=1
#CALYPSO_ARM2DSP_HS_A=1 #CALYPSO_ARM2DSP_HS_B=1 #CALYPSO_ARM2DSP_HS_C=1 #CALYPSO_ARM2DSP_HS_D=1 #CALYPSO_ARM2DSP_HS_E=1
#CALYPSO_POKE_A4C7_ONCE=1  # DIAG reverté (derail post-0x013b confirmé)

# ============================================================================
# CAPTURE / IQ (records + FIFOs grgsm)
# ============================================================================
CALYPSO_NB_DATAIND=1
CALYPSO_FORCE_NB=1
CALYPSO_SKIP_DEMOD_BRIDGE=0
CALYPSO_CANNED=              # vide = vrais SI décodés par grgsm
CALYPSO_IRDA_CAPTURE=0     
CALYPSO_IQDUMP=1             # [diag] 24 bursts → /tmp/iq_rx_NNN.bin
CALYPSO_BSP_INJECT_CANARY=0
BSP_DUMP_RX_FILE=/dev/shm/bursts.cfile
CALYPSO_SHUNT_IQ_CFILE=/dev/shm/dsp_iq.fifo  # FIFO live (mkfifo avant QEMU)
CALYPSO_SHUNT_IQ_RECORD=/dev/shm/dsp_iq.cfile # record disque (rejeu grgsm)
CALYPSO_UL_IQ_RECORD=/dev/shm/dsp_ul_iq.cfile
CALYPSO_RECORD_FILE=/dev/shm/record.cfile
CALYPSO_RELAY_FIFOS=/tmp/iq_fft.fifo:/tmp/iq_grgsm.fifo:/tmp/iq_grgsm_ciph.fifo:/tmp/iq_record.fifo:/tmp/iq_asciifft.fifo
 
# ============================================================================
# CHIFFREMENT A5/1
# ============================================================================
CALYPSO_CIPH_A5=             # vide = algo auto depuis /dev/shm/calypso_kc
CALYPSO_CIPH_FN_ADJ=0        # [tune]

# ============================================================================
# osmo-trx / UPLINK RACH / SDCCH  (section L1 ARM — inchangée, marche)
# ============================================================================
CALYPSO_START_FN=            # [REQUIS] horloge osmo-trx déterministe
CALYPSO_NB_MAXDLY=40         # [REQUIS >0] fenêtre TOA burst normal
CALYPSO_UL_DEBUG=
CALYPSO_UL_SLOT_OFFSET=      # gaté par mode qemu_wrap (c54x=0)
CALYPSO_UL_RA=               # vide = RA auto
CALYPSO_UL_FN_GATE=          # [REQUIS] RACH sur slot éligible
CALYPSO_UL_FN_OFFSET=        # ⚠️  CORRIGÉ : était 581 (override stale). c54x veut 0 → vide = défaut mode.
CALYPSO_UL_RACH_STICKY=      # [tune MT-SMS]
CALYPSO_REQREF_ADJ=          # [REQUIS] req-ref = FN exact du RACH_CONF
CALYPSO_UL_SABM_HOLD_TTL=2   # [REQUIS] hold court SABM
                                                              
CALYPSO_C54X_FORCE_IMR=       # 0x0008  # C2 : arme IMR bit3 (INT3) + clear INTM idle                                                                                                                                                                          
CALYPSO_C54X_BCTC_SM=1        # ← LA brique manquante : sortie boucle BC TC → setter
CALYPSO_SM_TRACE=1            # trace 098/scheduler sur 0xdde0-0xde9f
CALYPSO_F70_SETBIT1=1
CALYPSO_B3_TRACE=1
CALYPSO_WATCH_WR_ADDR=0x098a 
CALYPSO_DEBUG=WATCH-WR,RSBX-INTM,POPM-ST1,D_TASK_MD-RD
