     case 0x14: /* IRQ_CTRL */
     case 0x84: /* IRQ_CTRL (legacy) */
         return 0;
@@ -144,13 +188,34 @@ static void calypso_inth_write(void *opaque, hwaddr offset, uint64_t value,
 
     switch (offset) {
     case 0x08: /* MASK_IT_REG1 */
+    {
+        uint32_t old = s->mask;
         s->mask = (s->mask & 0xFFFF0000) | (value & 0xFFFF);
