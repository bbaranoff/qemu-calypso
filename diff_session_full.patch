     if (level) {
         s->levels |= (1u << irq);
     } else {
@@ -124,7 +154,21 @@ static uint64_t calypso_inth_read(void *opaque, hwaddr offset, unsigned size)
     }
     case 0x12: /* FIQ_NUM */
     case 0x82: /* FIQ_NUM (legacy) */
-        return s->ith_v;
+    {
+        /* AUDIT FIX 2026-05-08 night : returns separately-arbitrated FIQ
