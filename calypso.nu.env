# calypso.nu.env — LIGNE DE BASE NUE (2026-07-11) — AUDIT EXHAUSTIF des getenv.
# Sourcé APRÈS calypso.env par bash_scripts/start-clean.sh → DERNIER MOT.
# But : observer le VRAI DSP c54x SANS aucune perfusion (cheat / oracle / orchestration).
#
# ⚠️ PIÈGE getenv (vérifié run 492915 : "=0" laissait VEC28-FORCE tirer 30×) :
#   - présence-checked  `getenv(X)?1:0`         → "X=0" = "0" non-NULL = ACTIVÉ → il faut 'unset'.
#   - valeur défaut-ON  `!(e&&e[0]=='0')`/`!e`  → "X=0" coupe, mais 'unset' RÉ-ACTIVE → il faut "=0".
#   - valeur défaut-off `atoi>0`/`*e=='1'`      → "=0"/vide coupe.
#
# 4 OBSERVABLES à lire sur le run nu (sondes ci-dessous) :
#   (1) IMR bit3 armé par le firmware SEUL ?    (2) vec19@0x00CC : RETE ou handler installé ?
#   (3) go-live 0x3f70 bit1 atteint ?           (4) in_compute > 0 (entre le corrélateur) ?
# Revenir à l'avant : supprimer/renommer ce fichier (start-clean le teste avec [ -f ]).

# ============================================================================
# FIDÈLES (décode/signal corrects) → ON   (« nu » != « ému cassé »)
# ============================================================================
CALYPSO_DSP=c54x                 # vrai DSP c54x.
CALYPSO_DSP_SHUNT=0              # pas de shunt.
CALYPSO_FIX_SFTL_RSBX=1          # 0xF6BB=RSBX INTM décode correct -> sans lui, INTM jamais clair.
CALYPSO_FIX_PORTR=1              # sans lui, le corrélateur ne reçoit AUCUN échantillon I/Q.
CALYPSO_FIX_MVDM=1               # décode MVDM correct.
CALYPSO_FRAME_FAITHFUL=1         # periodic_armed = tpu_armed réel (pas orchestré).
CALYPSO_BSP_IQ_PASSTHROUGH=1     # vrai I/Q osmo-trx -> BSP -> DARAM -> corrélateur (signal réel BTS).

# ============================================================================
# SONDES RO (observation — n'injectent rien) → ON
# ============================================================================
CALYPSO_FBDET_SENTINEL=2         # MONITOR (pas de force) : logue la vraie valeur d_fb_det écrite.
CALYPSO_DEBUG=WATCH-WR,RSBX-INTM,POPM-ST1,D_TASK_MD-RD
CALYPSO_ORPHAN=1                 # trace RET/IT orphelins.
CALYPSO_FBWATCH=1                # watch FB.
CALYPSO_MEM_WATCH_2B80=1         # watch corrélateur 0x2b80.
CALYPSO_CALA_71DA=1              # cible CALA dispatcher 0x71c0 (RO).
CALYPSO_SM_TRACE=1               # trace 098/scheduler 0xdde0-0xde9f.
CALYPSO_B3_TRACE=1               # trace.
CALYPSO_WATCH_WR_ADDR=0x098a     # adresse watch handshake.
CALYPSO_IQDUMP=1                 # bursts -> /tmp/iq_rx_NNN.bin.

# ============================================================================
# CHEATS présence-checked (getenv()?1:0)  →  UNSET  (=0 les activerait)
# ============================================================================
unset CALYPSO_DSP_FRAME_VEC28    # pansement frame->vec28 (0x00f0 boot-poll -> derail). (c54x.c:4121 + :13928)
unset CALYPSO_SEED5AC8           # injectait mem[0x5ac8]=0x71f4 pour fabriquer go-live. (c54x.c:12147)
unset CALYPSO_C54X_BCTC_SM       # forçait la sortie de boucle TC @0xde0d-0xde26. (c54x.c:6407)
unset CALYPSO_ARM2DSP_CONT       # re-post continu du task-ready. (arm2dsp.c:95)
unset CALYPSO_DSP_GOLIVE_BOOT    # redirect go-live boot (expérience B). (c54x.c)
unset CALYPSO_POKE_A4C7_ONCE     # poke 0xA4C7 (dérail post-0x013b). (c54x.c)
unset CALYPSO_REDIR7000          # redirect PC->0x7000. (c54x.c)
unset CALYPSO_REDIR_LEGACY       # redirect legacy. (c54x.c)
unset CALYPSO_INITTAB            # force init table IT. (c54x.c)
unset CALYPSO_C54X_IRQ_LEVEL     # modif niveau IRQ. (c54x.c)
unset CALYPSO_F70_SETBIT1        # aucun consommateur trouvé, unset par propreté.

# ============================================================================
# CHEATS valeur DÉFAUT-ON (!(e&&e[0]=='0') / !e||*e!='0')  →  "=0"  (unset les ré-active !)
# ============================================================================
CALYPSO_FORCE_NB=0               # orchestration NB demod (gated orch). =0 OBLIGATOIRE.
CALYPSO_NB_DATAIND=0             # injection SI décodé grgsm dans les cellules DSP. =0 obligatoire.
CALYPSO_SHUNT_AGCH=0             # shunt-path (inerte en no_shunt) — explicite par sûreté.
CALYPSO_SHUNT_SACCH=0            # idem.
CALYPSO_SHUNT_SDCCH=0            # idem.

# ============================================================================
# CHEATS valeur défaut-off / FORCE_IMR  →  "=0" / vide
# ============================================================================
CALYPSO_C54X_FORCE_IMR=          # (e&&*e)?strtoul:0 -> vide coupe. Forçait IMR bit3.
CALYPSO_ARM2DSP=0                # atoi(e)>0 -> =0 coupe le module (rend CONT moot).
CALYPSO_FORCE_FBSB=0             # (a&&*a=='1') -> =0 coupe l'oracle L1.
CALYPSO_FORCE_AGCH=0             # (b&&*b=='1') -> =0. Oracle AGCH.
CALYPSO_FORCE_GOLIVE=            # (e&&atoi>0) -> vide coupe. Set brut 0x3f70 bit1.
CALYPSO_FORCE_098=               # poke DSP 098a/c. vide.
CALYPSO_FORCE_HS=                # override ARM 0x0314/0x0318. vide.
CALYPSO_FORCE_DP=                # force registre DP. vide.
CALYPSO_FORCE_TOA=               # force TOA. vide.
CALYPSO_FORCE_INTM_AT_PC=        # force INTM à un PC. vide.
CALYPSO_FORCE_INTM_ONESHOT=      # force INTM one-shot. vide.
CALYPSO_RACH_FORCE_BSIC=         # force BSIC RACH. vide.
CALYPSO_BSP_INJECT_CANARY=0      # pas d'injection canary.
CALYPSO_CANNED=                  # pas de SI canned.
CALYPSO_SEED5AC8=1           # injectait mem[0x5ac8]=0x71f4 pour fabriquer go-live. (c54x.c:12147)
